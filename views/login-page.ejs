<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Login</title>

    <link rel="stylesheet" href="/public/globals.css">
    <link rel="stylesheet" href="/public/login.css">
</head>

<body>
<h1 class="title">Hobbyt – Fun With Anyone, Anytime</h1>
<div class="login-wrapper">
    <div class="split-login-container">
        <!-- Left Side: Login -->
        <div class="login-section">
            <h2 class="section-title">Login</h2>
            <form class="login-form" id="loginForm">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input class="custom-input" type="text" id="username" placeholder="Enter username" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input class="custom-input" type="password" id="password" placeholder="Enter password" required>
                    <span id="loginErrorMessage" class="error-text">Wrong username or password</span>
                </div>
                <button type="submit" id="login"
                        class="myButton mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect mdl-button--accent">
                    Login
                </button>
            </form>
        </div>

        <div class="divider"></div>

        <!-- Right Side: Register -->
        <div class="register-section">
            <h2 class="section-title">New User?</h2>
            <p class="section-desc">Create an account to start managing your events.</p>
            <div class="login-form">
                <!-- Registration uses the same inputs for simplicity in this specific UI request -->
                <button id="register"
                        class="myButton mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect mdl-button--accent">
                    Register Now
                </button>
            </div>
        </div>
    </div>
</div>

<div id="error"></div>

<script type="text/javascript" src="/public/script.js"></script>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/material-design-lite/1.3.0/material.min.js"></script>
</body>

</html>