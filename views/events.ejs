<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Events</title>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jquery/2.1.4/jquery.min.js"></script>
    <link rel="stylesheet" href="/public/globals.css">
    <link rel="stylesheet" href="/public/events.css">
</head>

<body>
<h1 class="title">Hobbyt</h1>
<h2 class="sub-title">All events</h2>

<div class="eventsPageContainers">
    <div class="eventsLeftContainer mdl-data-table">
        <h2 class="section-title">Add New Event</h2>
        <form action="/item/" method="post">
            <div class="eventsInputField">
                <label for="activity"></label>
                <input class="mdl-text-field__input" name="activity" type="text" id="activity"
                       placeholder="Activity Type" required>
            </div>
            <div class="eventsInputField">
                <label for="name"></label>
                <input class="mdl-text-field__input" name="name" type="text" id="name" placeholder="Event Name" required>
            </div>
            <div class="eventsInputField">
                <label for="location"></label>
                <input class="mdl-text-field__input" name="location" type="text" id="location" placeholder="Location"
                       required>
            </div>
            <div class="eventsInputField">
                <label for="img"></label>
                <input class="mdl-text-field__input" name="img" type="url" id="img" placeholder="Image URL" required>
            </div>

            <div class="eventAddButton">
                <button class="myButton">
                    Add Event
                </button>
            </div>
        </form>
    </div>

    <div class="eventsRightContainer">
        <div class="tableContainer">
            <table class="mdl-data-table">

                <thead>
                <tr>
                    <th class="mdl-data-table__cell--non-numeric">Last Updated</th>
                    <th class="mdl-data-table__cell--non-numeric">Activity Type</th>
                    <th class="mdl-data-table__cell--non-numeric">Event name</th>
                    <th class="mdl-data-table__cell--non-numeric">Location</th>
                    <th class="mdl-data-table__cell--non-numeric">Image</th>
                    <th class="mdl-data-table__cell--non-numeric">Edit</th>
                    <th class="mdl-data-table__cell--non-numeric">Delete</th>
                </tr>
                </thead>

                <tbody>

                <% events.forEach(function(event){ %>
                    <tr id="row-<%= event.id %>" data-id="<%= event.id %>">

                        <!-- DATA -->
                        <td class="mdl-data-table__cell--non-numeric last-update" data-time="<%= event.time %>"></td>
                        <td class="mdl-data-table__cell--non-numeric editable"
                            data-field="activity"><%= event.activity %></td>
                        <td class="mdl-data-table__cell--non-numeric editable" data-field="name"><%= event.name %></td>
                        <td class="mdl-data-table__cell--non-numeric editable"
                            data-field="location"><%= event.location %></td>

                        <!-- ACTIONS -->
                        <td class="mdl-data-table__cell--non-numeric img-cell">
                            <a href="<%= event.img %>"
                               class="mdl-button mdl-js-button mdl-button--icon mdl-button--colored img-preview-trigger"
                               target="_blank">
                                <div class="material-icons md-dark">image</div>
                                <img src="<%= event.img %>" class="hover-preview" alt="Preview">
                            </a>
                        </td>

                        <td class="mdl-data-table__cell--non-numeric">
                            <div class="mdl-button mdl-js-button mdl-button--icon">
                                <i class="material-icons md-dark edit-btn">mode_edit</i>
                                <i class="material-icons md-dark save-btn" style="display:none;">save</i>
                            </div>
                        </td>

                        <td class="mdl-data-table__cell--non-numeric">
                            <div class="mdl-button mdl-js-button mdl-button--icon">
                                <i id="<%= event.id %>" class="material-icons md-dark delete">delete</i>
                            </div>
                        </td>

                    </tr>
                <% }); %>

                </tbody>
            </table>
        </div>

        <% events.forEach(function(event){ %>
            <div class="gallery">
                <a target="_blank" href="<%= event.img %>">
                    <img src="<%= event.img %>" alt="">
                </a>
                <div class="eventDescription"><%= event.name %></div>
            </div>
        <% }); %>

    </div>

</div>

<link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
<script type="text/javascript" src="/public/script.js"></script>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/material-design-lite/1.3.0/material.min.js"></script>
</body>

</html>